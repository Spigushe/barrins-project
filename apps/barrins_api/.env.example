# Copy this file to .env and fill in all REQUIRED values.
# Generate SECRET_KEY with: openssl rand -hex 32

# =============================================================================
# METADATA
# =============================================================================
PROJECT_NAME=Barrins Project/API
VERSION=1.0.0
API_STR=/api/v1

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Allowed values: development | staging | production
ENVIRONMENT=production
DEBUG=false

# =============================================================================
# DATABASE — REQUIRED
# =============================================================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mtg_analyzer
# Print SQL queries in logs (useful during development)
DATABASE_ECHO=false

# =============================================================================
# SECURITY — REQUIRED
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32
# Access token validity duration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token validity duration (in days)
REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT signing algorithm (do not change unless explicitly needed)
ALGORITHM=HS256
# Allowed CORS origins (JSON list)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# =============================================================================
# LOGGING
# =============================================================================
# Available levels: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
# Maximum log file size before rotation (bytes) — 10 MB by default
LOG_MAX_BYTES=10485760
# Number of backup files to keep after rotation
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# =============================================================================
# AUTO-INSCRIPTION & EMAIL VERIFICATION
# =============================================================================
# If false, POST /auth/signup creates an already-verified account and logs
# the user in immediately (tokens in the response) — no email sent, no
# EmailVerification row created. Temporary workaround while SMTP isn't
# configured yet; when false, SMTP_HOST/FRONTEND_BASE_URL below are no
# longer required even in production (never read in that mode). Flip back
# to true once SMTP_* is filled in — no code change needed either way.
REQUIRE_EMAIL_VERIFICATION=true
# Host for SMTP relay; empty in dev/test means console logging instead of
# real email. Required in production while REQUIRE_EMAIL_VERIFICATION=true.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=barrins-identity@gmail.com
VERIFICATION_CODE_TTL_MINUTES=15
VERIFICATION_MAX_ATTEMPTS=5
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# Frontend URL used to build the email verification link
# ({FRONTEND_BASE_URL}/verify-email). Only one frontend can be targeted —
# if multiple frontends share this backend (see
# myserver/docs/tamiyo_scroll.md), decide which one should receive
# verification links. Required (≠ default value) in production while
# REQUIRE_EMAIL_VERIFICATION=true.
FRONTEND_BASE_URL=http://localhost:5173
