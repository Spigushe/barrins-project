# Copy this file to .env and fill in all REQUIRED values.

# =============================================================================
# METADATA
# =============================================================================
PROJECT_NAME=Barrin's Identity
VERSION=0.1.0
API_STR=/api/v1

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Allowed values: development | staging | production
ENVIRONMENT=production
DEBUG=false

# =============================================================================
# DATABASE — REQUIRED
# =============================================================================
# barrins-identity owns its own database — never shared with barrins_api.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/barrins_identity
DATABASE_ECHO=false

# =============================================================================
# JWT (RS256) — REQUIRED
# =============================================================================
# Generate a key, then convert its newlines to literal \n escapes so it fits
# on one double-quoted line (python-dotenv decodes \n back to real newlines
# only inside double quotes):
#   openssl genrsa 2048 | awk '{printf "%s\\n", $0}'
# Paste the FULL output — including the -----BEGIN/END PRIVATE KEY----- lines
# — as the double-quoted value below. Never commit a real key.
JWT_PRIVATE_KEY="REPLACE_WITH_RSA_PRIVATE_KEY_PEM"
# Current signing key id — bump when rotating keys (see platform.md §13).
JWT_KID=2026-07
ACCESS_TOKEN_EXPIRE_MINUTES=10
REFRESH_TOKEN_EXPIRE_DAYS=7
SERVICE_TOKEN_EXPIRE_MINUTES=15

# =============================================================================
# ARGON2ID COST PARAMETERS
# =============================================================================
ARGON2_MEMORY_COST_KIB=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# =============================================================================
# RATE LIMITING
# =============================================================================
# slowapi spec applied to POST /auth/token, per IP.
LOGIN_RATE_LIMIT=5/minute

# =============================================================================
# CORS — REQUIRED
# =============================================================================
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
