# Copy this file to .env and fill in all REQUIRED values.

# =============================================================================
# METADATA
# =============================================================================
PROJECT_NAME=Barrin's Identity
VERSION=0.1.0
API_STR=/api/v1

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Allowed values: development | staging | production
ENVIRONMENT=production
DEBUG=false

# =============================================================================
# DATABASE — REQUIRED
# =============================================================================
# barrins-identity owns its own database — never shared with barrins_api.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/barrins_identity
DATABASE_ECHO=false

# =============================================================================
# JWT (RS256) — REQUIRED
# =============================================================================
# Generate with: openssl genrsa 2048 | tr '\n' '|' (then restore newlines,
# or pass as a single-line PEM with literal \n — see pydantic-settings docs
# for multi-line env values). Never commit a real key.
JWT_PRIVATE_KEY=REPLACE_WITH_RSA_PRIVATE_KEY_PEM
# Current signing key id — bump when rotating keys (see platform.md §13).
JWT_KID=2026-07
ACCESS_TOKEN_EXPIRE_MINUTES=10
REFRESH_TOKEN_EXPIRE_DAYS=7
SERVICE_TOKEN_EXPIRE_MINUTES=15

# =============================================================================
# ARGON2ID COST PARAMETERS
# =============================================================================
ARGON2_MEMORY_COST_KIB=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# =============================================================================
# RATE LIMITING
# =============================================================================
# slowapi spec applied to POST /auth/token, per IP.
LOGIN_RATE_LIMIT=5/minute

# =============================================================================
# CORS — REQUIRED
# =============================================================================
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# =============================================================================
# SELF-REGISTRATION & EMAIL VERIFICATION
# =============================================================================
# If false, POST /auth/signup creates an already-verified account and logs
# the user in immediately (tokens in the response) — no email sent, no
# EmailVerification row created. Temporary workaround while SMTP isn't
# configured yet; when false, SMTP_HOST/FRONTEND_BASE_URL below are no
# longer required even in production (never read in that mode). Flip back
# to true once SMTP_* is filled in — no code change needed either way.
REQUIRE_EMAIL_VERIFICATION=true
# Host for SMTP relay; empty in dev/test means console logging instead of
# real email. Required in production while REQUIRE_EMAIL_VERIFICATION=true.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=barrins-identity@gmail.com
VERIFICATION_CODE_TTL_MINUTES=15
VERIFICATION_MAX_ATTEMPTS=5
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# Frontend URL used to build the email verification link
# ({FRONTEND_BASE_URL}/verify-email). Required (≠ default value) in
# production while REQUIRE_EMAIL_VERIFICATION=true.
FRONTEND_BASE_URL=http://localhost:5173

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
