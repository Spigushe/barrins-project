# Python bytecode cache
__pycache__/
*.pyc
**/.venv/
**/*.egg*
**/.env

# Python test coverage reports
.coverage

# mkdocs build output
docs/site/

# api logs
apps/barrins_api/logs/

# Ansible ops (ops/my-server) — Constitution ss34: secrets never live in git,
# even encrypted. Allow-list rather than block-list: everything under
# secrets/ is ignored except *.example templates and READMEs, so a new
# secret file is safe by default regardless of what it's named.
ops/my-server/venv/
ops/my-server/.vault-password-file.txt
ops/my-server/secrets/**
!ops/my-server/secrets/**/*.example
!ops/my-server/secrets/**/README.md

# Generated from apps/<app>/README.md by docs/hooks/sync_readmes.py on every build.
# Add a new line here whenever an app gets a doc page under docs/content/**/<app>/.
docs/content/back/barrins_api/index.md
docs/content/back/barrins_identity/index.md
docs/content/front/tamiyo_scroll/index.md
