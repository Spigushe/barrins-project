[Unit]
Description={{r.app_name}} service
After=network-online.target

[Service]
Type=simple
User={{username}}
Restart=always
WorkingDirectory={{r.app_root}}
{% for key, value in r.env_vars.items() %}
Environment={{key}}={{value}}
{% endfor %}
ExecStart=/bin/bash -c 'source .venv/bin/activate && uvicorn {{r.entrypoint}} --host 127.0.0.1 --port {{r.port}}'

[Install]
WantedBy=multi-user.target
