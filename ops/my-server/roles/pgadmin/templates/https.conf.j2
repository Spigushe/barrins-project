server {
  listen  443 ssl;
  server_name {{ pgadmin_config.server_name }};

  ssl_certificate         /etc/letsencrypt/live/{{ pgadmin_config.server_name }}/fullchain.pem;
  ssl_certificate_key     /etc/letsencrypt/live/{{ pgadmin_config.server_name }}/privkey.pem;
  ssl_trusted_certificate /etc/letsencrypt/live/{{ pgadmin_config.server_name }}/fullchain.pem;

  include snippets/ssl-params.conf;

  access_log syslog:server=unix:/dev/log,nohostname;
  error_log syslog:server=unix:/dev/log,nohostname;

  client_max_body_size 50M;

  location / {
    proxy_set_header X-Scheme https;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_redirect off;
    proxy_pass http://127.0.0.1:{{ pgadmin_config.port }}/;
  }
}
