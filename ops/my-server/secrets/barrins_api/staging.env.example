# Template for secrets/barrins_api/staging.env (vault-encrypted, see
# secrets/README.md for how to create it). Mirrors
# barrins-project/apps/barrins_api/.env.example — re-sync by hand if that
# file changes upstream.
#
# Deployed to ~/projects/api-staging.barrins-codex.org/.env on every
# `ansible-playbook barrins_api.yml -e deploy_env=staging` run.
#
# DATABASE_URL below MUST point at a dedicated staging database — never
# reuse the production one, or staging testing will corrupt real data.

# =============================================================================
# METADATA
# =============================================================================
PROJECT_NAME=Barrins Project/API (staging)
VERSION=1.0.0
API_STR=/api/v1

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=staging
DEBUG=false

# =============================================================================
# DATABASE — REQUIRED — dedicated staging database, not production's
# =============================================================================
DATABASE_URL=postgresql+asyncpg://REPLACE_USER:REPLACE_PASSWORD@localhost:5432/REPLACE_STAGING_DB
DATABASE_ECHO=false

# =============================================================================
# SECURITY — REQUIRED
# =============================================================================
# Generate a DIFFERENT key than production with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
ALLOWED_ORIGINS=["https://tolaria-staging.barrins-codex.org","https://tamiyo-staging.barrins-codex.org"]

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# =============================================================================
# AUTO-INSCRIPTION & EMAIL VERIFICATION
# =============================================================================
# ENVIRONMENT=staging (not "production") means SMTP_HOST/FRONTEND_BASE_URL
# are NOT required even if this stays true — see app/config/base.py. Set to
# false anyway if you want signup to skip verification entirely on staging.
REQUIRE_EMAIL_VERIFICATION=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=barrins-identity@gmail.com
VERIFICATION_CODE_TTL_MINUTES=15
VERIFICATION_MAX_ATTEMPTS=5
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
FRONTEND_BASE_URL=https://tamiyo-staging.barrins-codex.org
