# Template for secrets/barrins_api/production.env (vault-encrypted, see
# secrets/README.md for how to create it). Mirrors
# barrins-project/apps/barrins_api/.env.example — re-sync by hand if that
# file changes upstream.
#
# Deployed to ~/projects/api.barrins-codex.org/.env on every
# `ansible-playbook barrins_api.yml` run.

# =============================================================================
# METADATA
# =============================================================================
PROJECT_NAME=Barrins Project/API
VERSION=1.0.0
API_STR=/api/v1

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=production
DEBUG=false

# =============================================================================
# DATABASE — REQUIRED
# =============================================================================
DATABASE_URL=postgresql+asyncpg://REPLACE_USER:REPLACE_PASSWORD@localhost:5432/REPLACE_DB
DATABASE_ECHO=false

# =============================================================================
# SECURITY — REQUIRED
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
# Every frontend served by this backend instance must be listed here.
# Production serves both Tolaria News and Tamiyo Scroll.
ALLOWED_ORIGINS=["https://tolaria.barrins-codex.org","https://tamiyo.barrins-codex.org"]

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# =============================================================================
# AUTO-INSCRIPTION & EMAIL VERIFICATION
# =============================================================================
# Required (SMTP_HOST/FRONTEND_BASE_URL below) while true. Set to false as a
# temporary workaround if SMTP isn't configured yet — see
# barrins-project/apps/barrins_api/.env.example for the full explanation.
REQUIRE_EMAIL_VERIFICATION=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=barrins-identity@gmail.com
VERIFICATION_CODE_TTL_MINUTES=15
VERIFICATION_MAX_ATTEMPTS=5
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# Only one frontend can receive verification links — decide which
# (see docs/content/ops/deployment/backend.md, "FRONTEND_BASE_URL" row).
FRONTEND_BASE_URL=https://tamiyo.barrins-codex.org
